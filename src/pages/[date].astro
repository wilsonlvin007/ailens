---
import Base from '../layouts/Base.astro';
const base = "/ailens";
import Hero from '../components/Hero.astro';
import Signals from '../components/Signals.astro';
import DeepDive from '../components/DeepDive.astro';
import { getDailyData, getAllDates } from '../lib/data';
import { formatWeekday } from '../lib/utils';

export function getStaticPaths() {
  const dates = getAllDates();
  return dates.map(date => ({ params: { date } }));
}

const { date } = Astro.params;
const data = getDailyData(date!);

if (!data) {
  return Astro.redirect('/');
}
---

<Base title={`AI 日报 · ${date}`}>
  <Hero
    date={date!}
    weekday={formatWeekday(date!)}
    items={data.items}
    deepDive={data.deep_dive}
  />
  <div class="hero-divider"></div>
  <div id="signals">
    <Signals items={data.items} />
  </div>
  {data.deep_dive && (
    <div id="deep-dive">
      <DeepDive topic={data.deep_dive.topic} content={data.deep_dive.content} />
    </div>
  )}
  <nav class="date-nav">
    <a href={`${base}/`} class="back-link">← 返回最新</a>
  </nav>
</Base>

<style>
  .date-nav {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }
  .back-link {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .back-link:hover {
    color: var(--accent);
  }

.hero-divider {
  height: 1px;
  background: var(--border);
  margin: 0;
}

</style>
