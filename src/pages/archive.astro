---
import Base from '../layouts/Base.astro';
const base = "/ailens";
import { getAllDates } from '../lib/data';
import { formatWeekday } from '../lib/utils';

const dates = getAllDates();

interface YearMonth {
  year: string;
  month: string;
  label: string;
  dates: string[];
}

const grouped: YearMonth[] = [];
let current: YearMonth | null = null;

for (const d of dates) {
  const [y, m] = d.split('-').slice(0, 2);
  const key = `${y}-${m}`;
  const label = `${y}年${parseInt(m)}月`;
  if (!current || current.year !== y || current.month !== m) {
    current = { year: y, month: m, label, dates: [] };
    grouped.push(current);
  }
  current.dates.push(d);
}
---

<Base title="归档">
  <section class="archive">
    <h1 class="archive-title">归档</h1>
    {dates.length === 0 ? (
      <p class="archive-empty">暂无历史日报。</p>
    ) : (
      <div class="archive-list">
        {grouped.map((group) => (
          <div class="archive-group">
            <h2 class="archive-month">{group.label}</h2>
            <div class="archive-items">
              {group.dates.map((d) => (
                <a href={`/${d}`} class="archive-item">
                  <span class="archive-date">{d.slice(5)}</span>
                  <span class="archive-weekday">{formatWeekday(d)}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Base>

<style>
  .archive { padding: 2.5rem 0; }
  .archive-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 2rem;
  }
  .archive-empty {
    color: var(--text-tertiary);
    font-size: 0.9375rem;
  }
  .archive-group {
    margin-bottom: 2rem;
  }
  .archive-month {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }
  .archive-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .archive-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.8125rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .archive-item:hover {
    border-color: var(--accent);
    background: var(--accent-light);
    color: var(--accent);
  }
  .archive-date {
    font-weight: 600;
    color: var(--text-primary);
  }
  .archive-weekday {
    color: var(--text-tertiary);
    font-size: 0.75rem;
  }
</style>
