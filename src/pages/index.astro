---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Signals from '../components/Signals.astro';
import DeepDive from '../components/DeepDive.astro';
import { getLatestDate, getDailyData, getRecentDates } from '../lib/data';
import { formatDate, formatWeekday } from '../lib/utils';

export function getStaticPaths() {
  // Always generate at least one page; actual data loaded client-side or at build
  return [{ params: {} }];
}

const latestDate = getLatestDate();

let data: ReturnType<typeof getDailyData> = null;
let recentDates: string[] = [];

if (latestDate) {
  data = getDailyData(latestDate);
  recentDates = getRecentDates(7);
}
---

<Base title={latestDate ? `AI 日报 · ${latestDate}` : 'AI Lens'}>
  {data ? (
    <>
      <Hero
        date={latestDate!}
        summary={data.summary}
        weekday={formatWeekday(latestDate!)}
      />
      
      {/* 今日速览 */}
      <section class="tldr">
        <p class="tldr-text">{data.summary}</p>
      </section>

      <Signals items={data.items} maxPerCategory={3} dateLink={`/${latestDate}`} />
      {data.deep_dive && (
        <DeepDive topic={data.deep_dive.topic} content={data.deep_dive.content} truncated detailUrl={`/${latestDate}`} />
      )}


      {/* 推荐阅读 */}
      {recentDates.length > 1 && (
        <section class="recommended">
          <h2 class="rec-title">你可能错过</h2>
          <div class="rec-grid">
            {recentDates.slice(1, 4).map((d) => {
              const dData = getDailyData(d);
              const head = dData?.items?.[0];
              if (!head) return null;
              return (
                <a href={`/${d}`} class="rec-card">
                  <span class="rec-date">{d.slice(5)} · {formatWeekday(d)}</span>
                  <span class="rec-headline">{head.title.slice(0, 30)}{head.title.length > 30 ? '…' : ''}</span>
                </a>
              );
            })}
          </div>
        </section>
      )}


      {/* 历史期刊 */}
      {recentDates.length > 0 && (
        <section class="recent">
          <h2 class="recent-title">近期日报</h2>
          <div class="recent-list">
            {recentDates.map((d) => {
              const isToday = d === latestDate;
              const dData = getDailyData(d);
              const summary = dData?.summary || '';
              return (
                <a href={`/${d}`} class:list={["recent-item", { "recent-today": isToday }]}>
                  <div class="recent-text">
                    <span class="recent-date">{d.slice(5)}</span>
                    <span class="recent-weekday">{formatWeekday(d)}</span>
                  </div>
                  {summary && (
                    <span class="recent-summary">{summary.slice(0, 40)}{summary.length > 40 ? '…' : ''}</span>
                  )}
                </a>
              );
            })}
          </div>
          <a href="/archive" class="recent-archive-link">查看完整归档 →</a>
        </section>
      )}
    </>
  ) : (
    <section class="empty-state">
      <div class="empty-icon">🔭</div>
      <h1 class="empty-title">AI Lens</h1>
      <p class="empty-desc">透过镜头看 AI 新闻</p>
      <p class="empty-hint">第一期日报即将发布，敬请期待。</p>
      <a href="/subscribe" class="empty-cta">立即订阅 →</a>
    </section>
  )}
</Base>

<style>
  .tldr {
    padding: 1.25rem 1.5rem;
    margin: 1rem 0 2rem;
    background: linear-gradient(135deg, #eef2ff, #f0f9ff);
    border-radius: 10px;
    border-left: 3px solid var(--accent);
  }
  .tldr-text {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  .recommended {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }
  .rec-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .rec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }
  .rec-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.875rem 1rem;
    background: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .rec-card:hover {
    border-color: var(--accent);
    background: var(--accent-light);
  }
  .rec-date {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
  }
  .rec-headline {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.5;
  }

  .recent {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }
  .recent-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .recent-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg-white);
    border-bottom: 1px solid var(--border-light);
    font-size: 0.875rem;
    transition: background 0.2s;
  }
  .recent-item:last-child {
    border-bottom: none;
  }
  .recent-item:hover {
    background: var(--accent-light);
  }
  .recent-today {
    background: var(--accent-light);
    border-left: 3px solid var(--accent);
  }
  .recent-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .recent-date {
    font-weight: 600;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }
  .recent-weekday {
    color: var(--text-tertiary);
    font-size: 0.75rem;
  }
  .recent-summary {
    color: var(--text-secondary);
    font-size: 0.8125rem;
    text-align: right;
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 400px;
  }
  .recent-archive-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .recent-archive-link:hover {
    color: var(--accent);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 8rem 0;
    text-align: center;
  }
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }
  .empty-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .empty-desc {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .empty-hint {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-bottom: 1.5rem;
  }
  .empty-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    background: var(--accent);
    color: white;
    border-radius: var(--radius);
    transition: background 0.2s;
  }
  .empty-cta:hover {
    background: #1d4ed8;
    color: white;
  }
</style>