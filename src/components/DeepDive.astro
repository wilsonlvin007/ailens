---
interface Props {
  topic: string;
  content: string;
  truncated?: boolean;
  detailUrl?: string;
}

const { topic, content, truncated = false, detailUrl } = Astro.props;

const previewLen = 150;
const plainText = content.replace(/\n\n/g, '');
const needsTruncation = truncated && plainText.length > previewLen;
const previewParagraphs = content.split('\n\n');
// 取前150字对应的段落数
let totalLen = 0;
let cutIndex = previewParagraphs.length;
for (let i = 0; i < previewParagraphs.length; i++) {
  totalLen += previewParagraphs[i].length;
  if (totalLen >= previewLen) {
    cutIndex = i + 1;
    break;
  }
}
---

<section class="deep-dive">
  <h2 class="deep-dive-title">
    <span class="deep-dive-icon">🔍</span>
    特写
  </h2>
  <h3 class="deep-dive-topic">{topic}</h3>
  <div class="deep-dive-content">
    {needsTruncation ? (
      <>
        {previewParagraphs.slice(0, cutIndex).map((p) => (
          <p>{p}</p>
        ))}
      </>
    ) : (
      previewParagraphs.map((p) => (
        <p>{p}</p>
      ))
    )}
  </div>
  {needsTruncation && detailUrl && (
    <a href={detailUrl} class="read-more">展开阅读 →</a>
  )}
</section>

<style>
  .deep-dive {
    margin: 2.5rem 0;
    padding: 2rem;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .deep-dive-title {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .deep-dive-icon {
    font-size: 0.875rem;
  }
  .deep-dive-topic {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }
  .deep-dive-content {
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--text-secondary);
  }
  .deep-dive-content p {
    margin-bottom: 1rem;
  }
  .deep-dive-content p:last-child {
    margin-bottom: 0;
  }
  .read-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    transition: color 0.2s;
  }
  .read-more:hover {
    color: var(--accent-hover);
  }
  @media (max-width: 640px) {
    .deep-dive { padding: 1.25rem; margin: 2rem 0; }
    .deep-dive-topic { font-size: 1.125rem; }
  }
</style>
