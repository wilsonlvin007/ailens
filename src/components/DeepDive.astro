---
interface Props {
  topic: string;
  content: string;
  truncated?: boolean;
  detailUrl?: string;
}

const { topic, content, truncated = false, detailUrl } = Astro.props;

const paragraphs = content.split('

');
const needsTruncation = truncated && content.length > 300;

let previewLen = 0;
let cutAt = paragraphs.length;
for (let i = 0; i < paragraphs.length; i++) {
  previewLen += paragraphs[i].length;
  if (previewLen >= 150) {
    cutAt = i + 1;
    break;
  }
}
---

<section class="deep-dive">
  <h2 class="deep-dive-title">
    <span class="deep-dive-icon">🔍</span>
    特写
  </h2>
  <h3 class="deep-dive-topic">{topic}</h3>
  <div class="deep-dive-content">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>
  {needsTruncation && (
    <button class="read-more" data-cut={cutAt}>展开阅读 →</button>
  )}
</section>

{needsTruncation && (
  <script>
    (function() {
      var btns = document.querySelectorAll('.read-more[data-cut]');
      btns.forEach(function(btn) {
        var container = btn.closest('.deep-dive');
        if (!container) return;
        var allParas = container.querySelectorAll('.deep-dive-content p');
        var showCount = parseInt(btn.dataset.cut) || allParas.length;
        if (showCount >= allParas.length) {
          btn.style.display = 'none';
          return;
        }
        for (var i = showCount; i < allParas.length; i++) {
          allParas[i].style.display = 'none';
        }
        btn.addEventListener('click', function() {
          var isExpanded = btn.textContent.indexOf('收起') >= 0;
          for (var i = showCount; i < allParas.length; i++) {
            allParas[i].style.display = isExpanded ? 'none' : '';
          }
          btn.textContent = isExpanded ? '展开阅读 →' : '收起 ↑';
        });
      });
    })();
  </script>
)}

<style>
  .deep-dive {
    margin: 2.5rem 0;
    padding: 2rem;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .deep-dive-title {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }
  .deep-dive-icon {
    font-size: 0.875rem;
  }
  .deep-dive-topic {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }
  .deep-dive-content {
    font-size: 0.9375rem;
    line-height: 1.9;
    color: var(--text-secondary);
  }
  .deep-dive-content p {
    margin-bottom: 1rem;
  }
  .deep-dive-content p:last-child {
    margin-bottom: 0;
  }
  .read-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    transition: color 0.2s;
  }
  .read-more:hover {
    color: var(--accent-hover);
  }
  @media (max-width: 640px) {
    .deep-dive { padding: 1.25rem; margin: 2rem 0; }
    .deep-dive-topic { font-size: 1.125rem; }
  }
</style>