---
interface NewsItem {
  id: string;
  title: string;
  category: string;
  importance: number;
  summary?: string;
  analysis?: string;
}

interface Props {
  date: string;
  weekday: string;
  items: NewsItem[];
  deepDive?: { topic: string };
}

const { date, weekday, items, deepDive } = Astro.props;

// 取 importance 最高的信号做钩子
const hookItem = items.reduce((max, item) =>
  (item.importance || 0) > (max.importance || 0) ? item : max, items[0]);

// 从 analysis 或 summary 中动态提取引导语
function extractTagline(item: NewsItem): string {
  const text = item.analysis || item.summary || '';
  const sentences = text.split(/[。；]/).map(s => s.trim()).filter(s => s.length >= 8);
  for (let i = sentences.length - 1; i >= 0; i--) {
    const s = sentences[i];
    if (s.length >= 8 && s.length <= 50) return s;
  }
  const first = (item.summary || '').split(/[。，；]/)[0]?.trim() || '';
  return first.length >= 6 ? first : '这件事值得关注';
}

const tagline = extractTagline(hookItem);

// 分类统计
const catMap: Record<string, string> = {
  technology: '技术', application: '应用', hardware: '硬件', thought: '思想',
};
const catCounts: Record<string, number> = {};
items.forEach(item => {
  const cat = item.category || 'other';
  catCounts[cat] = (catCounts[cat] || 0) + 1;
});
const catSummary = Object.entries(catCounts)
  .map(([cat, count]) => `${catMap[cat] || cat} ${count}`)
  .join(' · ');
---

<section class="hero">
  <div class="hero-inner">
    <p class="hero-slogan">每天 5 分钟，看透 AI 在发生什么</p>
    <div class="hero-hook">
      <h1 class="hero-hook-title">{hookItem.title}</h1>
      <p class="hero-hook-tagline">——{tagline}</p>
    </div>
    <div class="hero-meta">
      <span>今日 {items.length} 条</span>
      <span class="hero-meta-sep">·</span>
      <span>{catSummary}</span>
      <span class="hero-meta-sep">·</span>
      <time datetime={date} class="hero-meta-date">{date}</time>
      <span class="hero-meta-weekday">{weekday}</span>
    </div>
    <div class="hero-actions">
      <a href="#signals" class="hero-btn hero-btn-primary">→ 今日焦点</a>
      <a href="#deep-dive" class="hero-btn hero-btn-secondary">→ 深度分析</a>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <span class="hero-scroll-text">↓</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 6rem 1.25rem 3rem;
  }

  .hero-inner {
    max-width: var(--max-width);
    width: 100%;
  }

  /* slogan */
  .hero-slogan {
    font-size: 1rem;
    color: var(--text-tertiary);
    font-weight: 400;
    letter-spacing: 0.02em;
    margin-bottom: 2.5rem;
  }

  /* 今日钩子 */
  .hero-hook {
    margin-bottom: 2.5rem;
  }
  .hero-hook-title {
    font-family: var(--font-serif);
    font-size: 3.75rem;
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1rem;
    /* 纯白：暗色主题下更亮 */
    color: #ffffff;
  }
  [data-theme="light"] .hero-hook-title {
    color: #0a0a0a;
  }
  .hero-hook-tagline {
    font-size: 1.125rem;
    color: var(--text-secondary);
    font-weight: 400;
    line-height: 1.6;
  }

  /* 概览数字 */
  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .hero-meta-sep {
    color: var(--border);
  }
  .hero-meta-date {
    font-variant-numeric: tabular-nums;
  }

  /* 按钮并排 */
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: var(--radius);
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }
  .hero-btn-primary {
    background: var(--accent);
    color: white;
  }
  .hero-btn-primary:hover {
    color: white;
    opacity: 0.85;
  }
  .hero-btn-secondary {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }
  .hero-btn-secondary:hover {
    border-color: var(--text-tertiary);
    color: var(--text-primary);
  }

  /* 底部滚动提示 */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }
  .hero-scroll-text {
    font-size: 1.25rem;
    color: var(--text-tertiary);
    animation: bounce 2s ease-in-out infinite;
    display: block;
    line-height: 1;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* 移动端 */
  @media (max-width: 640px) {
    .hero {
      min-height: 85vh;
      padding: 4rem 1rem 2.5rem;
    }
    .hero-hook-title {
      font-size: 1.875rem;
      line-height: 1.35;
    }
    .hero-hook-tagline {
      font-size: 1rem;
    }
    .hero-slogan {
      font-size: 0.875rem;
      margin-bottom: 2rem;
    }
    .hero-meta {
      font-size: 0.75rem;
      margin-bottom: 2rem;
    }
    .hero-actions {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .hero-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
