---
import fs from 'node:fs';
import path from 'node:path';

// === Types ===
interface HeroItem {
  id: string;
  level: 1 | 2 | 3;
  content: string;
  summary?: string;
  source?: string;
  date: string;
}
interface HeroState {
  updated_at: string;
  items: HeroItem[];
}

// === Hash ===
function hash(str: string): number {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = ((h << 5) - h + str.charCodeAt(i)) | 0;
  return Math.abs(h);
}
function hashF(seed: number): number {
  const x = Math.sin(seed * 9301 + 49297) * 233280;
  return x - Math.floor(x);
}

// === Load hero-state.json ===
function loadHeroState(): HeroState | null {
  const candidates = [
    path.join(process.cwd(), 'public', 'data', 'hero-state.json'),
    path.join(process.cwd(), 'src', 'data', 'hero-state.json'),
  ];
  for (const p of candidates) {
    if (fs.existsSync(p)) return JSON.parse(fs.readFileSync(p, 'utf-8'));
  }
  return null;
}

const state = loadHeroState();
const items = state?.items || [];
const l1 = items.filter(i => i.level === 1).slice(0, 3);
const l2 = items.filter(i => i.level === 2).slice(0, 8);
const l3 = items.filter(i => i.level === 3).slice(0, 6);

// === Collision-free placement engine ===
// Reference canvas: 1000 × 1000 (abstract units)
// All positions as % of this canvas.
// L1/L2/L3 have FIXED pixel sizes — not relative to canvas.

interface PlacedItem {
  id: string;
  level: 1 | 2 | 3;
  content: string;
  summary?: string;
  source?: string;
  x: number;       // % from left
  y: number;       // % from top
  w: number;       // % width (estimated)
  h: number;       // % height (estimated)
  animAmp: number;  // float amplitude px
  animPeriod: number; // float period s
  animDelay: number;  // float delay s
  offX: number;     // static offset px
  offY: number;
}

// Estimate rendered size of each element in px (fixed, not relative to container)
function estimateSize(item: HeroItem): { w: number; h: number } {
  if (item.level === 1) {
    const charW = 22; // 1.5rem CJK char width
    const titleW = item.content.length * charW;
    return {
      w: Math.min(Math.max(titleW + 56, 240), 380),  // padding + clamp
      h: item.summary ? 110 : 80,
    };
  } else if (item.level === 2) {
    const charW = 14;
    return {
      w: item.content.length * charW + 32,
      h: 34,
    };
  } else {
    const charW = 10;
    return {
      w: Math.max(item.content.length * charW, 40),
      h: 22,
    };
  }
}

// Convert px to % of reference canvas (1000px)
const REF = 1400;
function px2pct(px: number): number { return (px / REF) * 100; }

function overlaps(a: PlacedItem, b: PlacedItem, gap: number = 12): boolean {
  const gapPct = px2pct(gap);
  return (
    Math.abs(a.x - b.x) < (a.w + b.w) / 2 + gapPct &&
    Math.abs(a.y - b.y) < (a.h + b.h) / 2 + gapPct
  );
}

function placeElement(
  item: HeroItem,
  placed: PlacedItem[],
  minDist: number,
  maxDist: number,
): PlacedItem | null {
  const size = estimateSize(item);
  const h = hash(item.id);

  for (let attempt = 0; attempt < 200; attempt++) {
    const angle = hashF(h + attempt * 7.1) * Math.PI * 2;
    const dist = minDist + hashF(h + attempt * 13.3) * (maxDist - minDist);

    let x = 50 + Math.cos(angle) * dist;
    let y = 50 + Math.sin(angle) * dist;

    // Clamp within canvas bounds (leave margin)
    const mx = size.w / REF / 2 * 100 + 2;
    const my = size.h / REF / 2 * 100 + 2;
    x = Math.max(mx, Math.min(100 - mx, x));
    y = Math.max(my, Math.min(100 - my, y));

    const candidate: PlacedItem = {
      id: item.id,
      level: item.level,
      content: item.content,
      summary: item.summary,
      source: item.source,
      x, y,
      w: px2pct(size.w),
      h: px2pct(size.h),
      animAmp: item.level === 1 ? 6 + hashF(h + 100) * 4 : item.level === 2 ? 4 + hashF(h + 200) * 3 : 2 + hashF(h + 300) * 2,
      animPeriod: item.level === 1 ? 6 + hashF(h + 400) * 3 : item.level === 2 ? 4 + hashF(h + 500) * 3 : 3 + hashF(h + 600) * 2,
      animDelay: (hash(item.id + '_d') % 40) / 10,
      offX: (hashF(h + 700) - 0.5) * 16,
      offY: (hashF(h + 800) - 0.5) * 10,
    };

    const hasOverlap = placed.some(p => overlaps(candidate, p));
    if (!hasOverlap) return candidate;
  }

  return null; // give up if can't place
}

// Place all items: L1 near center, L2 middle ring, L3 outer ring
const placed: PlacedItem[] = [];

// L1: center zone (10-28% from center)
for (const item of l1) {
  const p = placeElement(item, placed, 10, 28);
  if (p) placed.push(p);
}
// L2: middle ring (18-42% from center)
for (const item of l2) {
  const p = placeElement(item, placed, 18, 42);
  if (p) placed.push(p);
}
// L3: outer ring (28-55% from center)
for (const item of l3) {
  const p = placeElement(item, placed, 28, 55);
  if (p) placed.push(p);
}

// === Background stars ===
const stars = Array.from({ length: 50 }, (_, i) => ({
  x: hashF(i * 1.1 + 0.3) * 100,
  y: hashF(i * 2.3 + 0.7) * 100,
  r: hashF(i * 3.7 + 1.1) > 0.85 ? 1.5 : 0.4 + hashF(i * 4.1) * 0.6,
  o: 0.04 + hashF(i * 5.1 + 2.3) * 0.1,
}));
const starShadow = stars.map(s =>
  `${s.x.toFixed(1)}vw ${s.y.toFixed(1)}vh 0 ${s.r.toFixed(1)}px rgba(140,150,255,${s.o.toFixed(2)})`
).join(',');

// === Props (backwards compat) ===
interface Props { date?: string; weekday?: string; items?: any[]; deepDive?: any; }
Astro.props;
---

<section class="nebula" aria-label="AI 资讯星云">
  <div class="nebula-bg" style={`--stars:${starShadow}`}></div>

  {placed.map(item => (
    item.level === 1 ? (
      <a
        href={item.source || '#signals'}
        target={item.source ? '_blank' : undefined}
        rel={item.source ? 'noopener noreferrer' : undefined}
        class="n n-l1"
        style={`
          left:${item.x.toFixed(1)}%;top:${item.y.toFixed(1)}%;
          --amp:${item.animAmp.toFixed(1)}px;
          --per:${item.animPeriod.toFixed(1)}s;
          --del:${item.animDelay.toFixed(1)}s;
          --ox:${item.offX.toFixed(0)}px;
          --oy:${item.offY.toFixed(0)}px;
        `}
      >
        <div class="n-l1-inner">
          <h2 class="n-l1-title">{item.content}</h2>
          {item.summary && <p class="n-l1-sub">{item.summary}</p>}
        </div>
      </a>
    ) : item.level === 2 ? (
      <span
        class="n n-l2"
        style={`
          left:${item.x.toFixed(1)}%;top:${item.y.toFixed(1)}%;
          --amp:${item.animAmp.toFixed(1)}px;
          --per:${item.animPeriod.toFixed(1)}s;
          --del:${item.animDelay.toFixed(1)}s;
          --ox:${item.offX.toFixed(0)}px;
          --oy:${item.offY.toFixed(0)}px;
        `}
      >{item.content}</span>
    ) : (
      <span
        class="n n-l3"
        style={`
          left:${item.x.toFixed(1)}%;top:${item.y.toFixed(1)}%;
          --amp:${item.animAmp.toFixed(1)}px;
          --per:${item.animPeriod.toFixed(1)}s;
          --del:${item.animDelay.toFixed(1)}s;
          --ox:${item.offX.toFixed(0)}px;
          --oy:${item.offY.toFixed(0)}px;
        `}
      >{item.content}</span>
    )
  ))}

  <a href="#signals" class="nebula-scroll"><span>↓</span></a>
</section>

<style>
  .nebula {
    position: relative;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    min-height: 100vh;
    overflow: hidden;
  }

  /* ── Background ── */
  .nebula-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 50% 45% at 50% 50%, rgba(120,130,255,0.07) 0%, transparent 100%),
      var(--bg);
  }
  .nebula-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    width: 1px; height: 1px;
    background: transparent;
    box-shadow: var(--stars);
  }
  [data-theme="light"] .nebula-bg {
    background:
      radial-gradient(ellipse 50% 45% at 50% 50%, rgba(100,110,230,0.03) 0%, transparent 100%),
      var(--bg);
  }
  [data-theme="light"] .nebula-bg::before {
    filter: brightness(0.12);
  }

  /* ── Shared: absolute positioned, centered on point ── */
  .n {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 1;
    text-decoration: none;
    color: inherit;
    animation: float var(--per, 5s) ease-in-out var(--del, 0s) infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(calc(-50% + var(--ox, 0px)), calc(-50% + var(--oy, 0px) - var(--amp, 4px)));
    }
    50% {
      transform: translate(calc(-50% + var(--ox, 0px) + 1.5px), calc(-50% + var(--oy, 0px) + var(--amp, 4px)));
    }
  }

  /* ═══ L1: Title card — fixed size, largest ═══ */
  .n-l1 {
    z-index: 3;
    cursor: pointer;
  }
  .n-l1-inner {
    padding: 1rem 1.25rem;
    max-width: 340px;        /* fixed width */
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    backdrop-filter: blur(8px);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }
  .n-l1-inner::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--accent);
    opacity: 0.45;
    border-radius: 0 2px 2px 0;
  }
  .n-l1:hover .n-l1-inner {
    transform: scale(1.05);
    background: rgba(255,255,255,0.07);
    box-shadow: 0 0 50px rgba(120,130,255,0.1);
  }
  [data-theme="light"] .n-l1-inner {
    background: rgba(0,0,0,0.03);
    border-color: rgba(0,0,0,0.06);
  }
  [data-theme="light"] .n-l1-inner::before { opacity: 0.25; }
  [data-theme="light"] .n-l1:hover .n-l1-inner {
    background: rgba(0,0,0,0.055);
  }

  .n-l1-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;       /* fixed size */
    font-weight: 900;
    line-height: 1.35;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin: 0;
  }
  [data-theme="light"] .n-l1-title { color: #0a0a0a; }

  .n-l1-sub {
    margin: 0.4rem 0 0;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.5;
  }

  /* ═══ L2: Topic tag — fixed font size, pill ═══ */
  .n-l2 {
    z-index: 2;
    padding: 0.35rem 0.9rem;
    font-size: 0.875rem;     /* fixed size */
    font-weight: 500;
    white-space: nowrap;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 999px;
    transition: transform 0.3s, color 0.3s, border-color 0.3s;
  }
  .n-l2:hover {
    transform: translate(-50%,-50%) scale(1.12);
    color: #fff !important;
    border-color: rgba(255,255,255,0.25) !important;
  }
  [data-theme="light"] .n-l2 {
    color: rgba(0,0,0,0.45);
    border-color: rgba(0,0,0,0.07);
  }
  [data-theme="light"] .n-l2:hover {
    color: #000 !important;
    border-color: rgba(0,0,0,0.2) !important;
  }

  /* ═══ L3: Ghost word — fixed font size, bare text ═══ */
  .n-l3 {
    z-index: 1;
    font-size: 0.75rem;     /* fixed size */
    font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    opacity: 0.32;
    white-space: nowrap;
    transition: opacity 0.3s, color 0.3s;
  }
  .n-l3:hover {
    opacity: 0.85;
    color: var(--text-secondary);
  }

  /* ── Scroll hint ── */
  .nebula-scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    text-decoration: none;
  }
  .nebula-scroll span {
    font-size: 1.25rem;
    color: var(--text-tertiary);
    opacity: 0.4;
    animation: bounce 2s ease-in-out infinite;
    line-height: 1;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ── Mobile: stack vertically ── */
  @media (max-width: 640px) {
    .nebula { min-height: auto; padding: 2rem 0; width: 100%; margin-left: 0; }

    .n {
      position: static !important;
      transform: none !important;
      animation: none !important;
      display: block;
      margin: 0 auto;
    }
    .n-l1 { margin-bottom: 1rem; max-width: 92vw; }
    .n-l1:nth-of-type(1) ~ .n-l1 { display: none; }
    .n-l2 { display: inline-block; margin: 0.2rem; opacity: 1; }
    .n-l2:nth-of-type(n+6) { display: none; }
    .n-l3 { display: inline; margin: 0 0.4rem; opacity: 0.35; font-size: 0.7rem; }
    .n-l3:nth-of-type(n+5) { display: none; }

    .nebula-scroll { display: none; }
    .nebula-bg::before { display: none; }
  }
</style>
