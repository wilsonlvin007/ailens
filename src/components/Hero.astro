---
import fs from 'node:fs';
import path from 'node:path';

// === Types ===
interface HeroItem {
  id: string;
  level: 1 | 2 | 3;
  content: string;
  summary?: string;
  source?: string;
  date: string;
  signal_index?: number;
}
interface HeroState {
  updated_at: string;
  items: HeroItem[];
}

// === Hash ===
function hash(str: string): number {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = ((h << 5) - h + str.charCodeAt(i)) | 0;
  return Math.abs(h);
}
function hashF(seed: number): number {
  const x = Math.sin(seed * 9301 + 49297) * 233280;
  return x - Math.floor(x);
}

// === Load hero-state.json ===
function loadHeroState(): HeroState | null {
  const candidates = [
    path.join(process.cwd(), 'public', 'data', 'hero-state.json'),
    path.join(process.cwd(), 'src', 'data', 'hero-state.json'),
  ];
  for (const p of candidates) {
    if (fs.existsSync(p)) return JSON.parse(fs.readFileSync(p, 'utf-8'));
  }
  return null;
}

const state = loadHeroState();
const items = state?.items || [];
const l1 = items.filter(i => i.level === 1).slice(0, 15);
const l2 = items.filter(i => i.level === 2).slice(0, 10);
const l3 = items.filter(i => i.level === 3).slice(0, 14);

// === Grid-based placement engine ===
// Virtual grid: COLS × ROWS. L1 occupies grid cells (1×1).
// Positions are % of the nebula container.
// Each cell center = ((col + 0.5) / COLS * 100, (row + 0.5) / ROWS * 100)
// with random jitter ±30% of cell size for organic feel.
// VERTICAL OFFSET: shift center up by ~3% to visually align with Signals section
// (compensates for header height affecting perceived center)

const COLS = 7;
const ROWS = 5;
const CELL_W = 100 / COLS;  // ~11.1%
const CELL_H = 100 / ROWS; // ~20%
const V_OFFSET = -2.8; // shift all items up to align with content center

interface GridCell {
  col: number;
  row: number;
  cx: number; // center x %
  cy: number; // center y %
  distToCenter: number; // distance from center cell (0,0 at center)
}

// Generate all grid cells with distance to center
const centerCol = Math.floor(COLS / 2);
const centerRow = Math.floor(ROWS / 2);
const allCells: GridCell[] = [];
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    const dx = c - centerCol;
    const dy = r - centerRow;
    allCells.push({
      col: c, row: r,
      cx: (c + 0.5) / COLS * 100,
      cy: (r + 0.5) / ROWS * 100 + V_OFFSET,
      distToCenter: Math.sqrt(dx * dx + dy * dy),
    });
  }
}
// Sort by distance to center (center first)
allCells.sort((a, b) => a.distToCenter - b.distToCenter);

// Track which cells are occupied
const occupied = new Set<string>();
function cellKey(col: number, row: number): string { return `${col},${row}`; }

interface PlacedItem {
  id: string;
  level: 1 | 2 | 3;
  content: string;
  summary?: string;
  source?: string;
  signal_index?: number;
  x: number;
  y: number;
  depth: 'fg' | 'mg' | 'bg';  // foreground / midground / background
  animAmp: number;
  animPeriod: number;
  animDelay: number;
  offX: number;
  offY: number;
}

function makeAnim(item: HeroItem): { amp: number; per: number; del: number; ox: number; oy: number } {
  const h = hash(item.id);
  const base = { amp: 2, per: 3, del: 0, ox: 0, oy: 0 };
  if (item.level === 1) {
    base.amp = 4 + hashF(h + 100) * 3;
    base.per = 6 + hashF(h + 400) * 3;
  } else if (item.level === 2) {
    base.amp = 3 + hashF(h + 200) * 2;
    base.per = 5 + hashF(h + 500) * 3;
  } else {
    base.amp = 1.5 + hashF(h + 300) * 1.5;
    base.per = 4 + hashF(h + 600) * 2;
  }
  base.del = (hash(item.id + '_d') % 40) / 10;
  base.ox = (hashF(h + 700) - 0.5) * 12;
  base.oy = (hashF(h + 800) - 0.5) * 8;
  // Ensure all values are finite numbers
  return {
    amp: base.amp || 2,
    per: base.per || 3,
    del: base.del || 0,
    ox: base.ox || 0,
    oy: base.oy || 0,
  };
}

// Jitter: random offset within cell (±35% of cell size)
function jitter(h: number, cell: GridCell): { x: number; y: number } {
  const jx = (hashF(h * 3 + cell.col * 7 + cell.row * 13) - 0.5) * CELL_W * 0.7;
  const jy = (hashF(h * 5 + cell.col * 11 + cell.row * 17) - 0.5) * CELL_H * 0.7;
  return { x: cell.cx + jx, y: cell.cy + jy };
}

const placed: PlacedItem[] = [];

// === Step 1: Place L1 ===
// L1[0] → center cell (centerCol, centerRow)
// L1[1-4] → center column: up2, up1, down1, down2
// L1[5-6] → left, right (fill horizontal)
if (l1.length > 0) {
  const centerCell = allCells.find(c => c.col === centerCol && c.row === centerRow)!;
  occupied.add(cellKey(centerCell.col, centerCell.row));
  const anim0 = makeAnim(l1[0]);
  placed.push({
    id: l1[0].id, level: 1, content: l1[0].content,
    signal_index: l1[0].signal_index ?? 0,
    x: centerCell.cx, y: centerCell.cy,
    depth: 'fg',
    ...anim0,
  });

  // 4 cardinal cells: up, right, down, left (skip 1 cell for spacing)
  const cardinals = [
    { col: centerCol, row: centerRow - 2 },     // up2 (far)
    { col: centerCol, row: centerRow - 1 },     // up1 (near)
    { col: centerCol, row: centerRow + 1 },     // down1 (near)
    { col: centerCol, row: centerRow + 2 },     // down2 (far)
  ];
  // 4 diagonal cells at distance 2
  const diagonals = [
    { col: centerCol - 1, row: centerRow - 1 }, // NW
    { col: centerCol + 1, row: centerRow - 1 }, // NE
    { col: centerCol - 1, row: centerRow + 1 }, // SW
    { col: centerCol + 1, row: centerRow + 1 }, // SE
  ];

  // Place L1[1-4] in cardinal cells
  for (let i = 1; i < l1.length && i <= 4; i++) {
    const target = cardinals[i - 1];
    const cell = allCells.find(c => c.col === target.col && c.row === target.row);
    if (!cell || occupied.has(cellKey(cell.col, cell.row))) continue;
    occupied.add(cellKey(cell.col, cell.row));
    const anim = makeAnim(l1[i]);
    placed.push({
      id: l1[i].id, level: 1, content: l1[i].content,
      signal_index: l1[i].signal_index ?? 0,
      x: cell.cx + (hashF(hash(l1[i].id) * 3 + i * 7) - 0.5) * 5,
      y: cell.cy + (hashF(hash(l1[i].id) * 5 + i * 11) - 0.5) * 5,
      depth: 'mg',
      ...anim,
    });
  }

  // L1[5-14] → fill left/right at all 5 rows
  const extraL1Positions = [];
  for (const dr of [-2, -1, 1, 2]) {
    extraL1Positions.push({ col: centerCol - 1, row: centerRow + dr }); // left
    extraL1Positions.push({ col: centerCol + 1, row: centerRow + dr }); // right
  }
  for (let i = 5; i < Math.min(l1.length, extraL1Positions.length + 5); i++) {
    const pos = extraL1Positions[i - 5];
    if (!pos) continue;
    const cell = allCells.find(c => c.col === pos.col && c.row === pos.row);
    if (!cell || occupied.has(cellKey(cell.col, cell.row))) continue;
    occupied.add(cellKey(cell.col, cell.row));
    const itemSeed = hash(l1[i].id);
    const jx = (hashF(itemSeed * 3 + cell.col * 7 + cell.row * 13) - 0.5) * CELL_W * 0.2;
    const jy = (hashF(itemSeed * 5 + cell.col * 11 + cell.row * 17) - 0.5) * CELL_H * 0.2;
    const anim = makeAnim(l1[i]);
    placed.push({
      id: l1[i].id, level: 1, content: l1[i].content,
      signal_index: l1[i].signal_index ?? 0,
      x: cell.cx + jx, y: cell.cy + jy,
      depth: 'bg',
      ...anim,
    });
  }
}

// === Step 2: Place L2 — in empty cells of the 3×3 grid, max 2 per cell ===
const surroundCells = allCells.filter(c =>
  Math.abs(c.col - centerCol) <= 1 && Math.abs(c.row - centerRow) <= 1
);
const l2GridCells = surroundCells.filter(c => !occupied.has(cellKey(c.col, c.row)));
// Shuffle cells for randomness
for (let si = l2GridCells.length - 1; si > 0; si--) {
  const sj = Math.floor(hashF(hash(`l2cell${si}`) + si * 1.7) * (si + 1));
  [l2GridCells[si], l2GridCells[sj]] = [l2GridCells[sj], l2GridCells[si]];
}
// Distribute L2: max 2 per cell, spread evenly
const maxL2 = Math.min(6, l2.length);
let l2Idx = 0;
for (const cell of l2GridCells) {
  if (l2Idx >= maxL2) break;
  const cellCount = Math.min(2, maxL2 - l2Idx);
  for (let ci = 0; ci < cellCount; ci++) {
    const itemSeed = hash(l2[l2Idx].id);
    // Two items in same cell: offset in opposite directions to avoid overlap
    const dir = ci === 0 ? -1 : 1;
    const jx = dir * (0.1 + hashF(itemSeed * 3 + cell.col * 7) * 0.25) * CELL_W;
    const jy = dir * (0.1 + hashF(itemSeed * 5 + cell.row * 11) * 0.25) * CELL_H;
    const anim = makeAnim(l2[l2Idx]);
    placed.push({
      id: l2[l2Idx].id, level: 2, content: l2[l2Idx].content,
      x: cell.cx + jx, y: cell.cy + jy,
      ...anim,
    });
    l2Idx++;
  }
}

// === Step 3: Place L3 — fill gaps within 3×3 grid, no overlap ===
const gridLeft = (centerCol - 1 + 0.2) / COLS * 100;
const gridRight = (centerCol + 1 + 0.8) / COLS * 100;
const gridTop = (centerRow - 1 + 0.2) / ROWS * 100 + V_OFFSET;
const gridBottom = (centerRow + 1 + 0.8) / ROWS * 100 + V_OFFSET;

// Estimate item half-sizes (in %) for overlap check
function halfSize(level: number): { hw: number; hh: number } {
  if (level === 1) return { hw: 5.5, hh: 2 };
  if (level === 2) return { hw: 3, hh: 1.2 };
  return { hw: 2, hh: 0.8 };
}
function overlapsAny(x: number, y: number, hw: number, hh: number): boolean {
  const gap = 0.8;
  return placed.some(p => {
    const ps = halfSize(p.level);
    return Math.abs(x - p.x) < hw + ps.hw + gap &&
           Math.abs(y - p.y) < hh + ps.hh + gap;
  });
}
const maxL3 = Math.min(l3.length, 12);
for (let i = 0; i < maxL3; i++) {
  const itemSeed = hash(l3[i].id);
  let ok = false;
  for (let attempt = 0; attempt < 80; attempt++) {
    const rx = gridLeft + hashF(itemSeed + attempt * 3.1 + i * 7) * (gridRight - gridLeft);
    const ry = gridTop + hashF(itemSeed + attempt * 5.3 + i * 11) * (gridBottom - gridTop);
    if (!overlapsAny(rx, ry, 2, 0.8)) {
      const anim = makeAnim(l3[i]);
      placed.push({
        id: l3[i].id, level: 3, content: l3[i].content,
        x: rx, y: ry,
        ...anim,
      });
      ok = true;
      break;
    }
  }
}

// Safety: filter out any placed items with undefined x/y
const safePlaced = placed.filter(p => p.x != null && p.y != null);

// === Background stars ===
const stars = Array.from({ length: 50 }, (_, i) => ({
  x: hashF(i * 1.1 + 0.3) * 100,
  y: hashF(i * 2.3 + 0.7) * 100,
  r: hashF(i * 3.7 + 1.1) > 0.85 ? 1.5 : 0.4 + hashF(i * 4.1) * 0.6,
  o: 0.04 + hashF(i * 5.1 + 2.3) * 0.1,
}));
const starShadow = stars.map(s =>
  `${s.x.toFixed(1)}vw ${s.y.toFixed(1)}vh 0 ${s.r.toFixed(1)}px rgba(140,150,255,${s.o.toFixed(2)})`
).join(',');

// === Props (backwards compat) ===
interface Props { date?: string; weekday?: string; items?: any[]; deepDive?: any; }
Astro.props;
---

<section class="nebula" aria-label="AI 资讯星云">
  <div class="nebula-bg" style={`--stars:${starShadow}`}></div>

  {safePlaced.map(item => (
    item.level === 1 ? (
      <a
        href={`#signal-${item.signal_index ?? 0}`}
        class={`n n-l1 ${item.depth === 'fg' ? 'n-l1-fg' : item.depth === 'mg' ? 'n-l1-mg' : 'n-l1-bg'}`}
        data-depth={item.depth}
        style={`
          left:${(item.x ?? 50).toFixed(1)}%;top:${(item.y ?? 50).toFixed(1)}%;
          --amp:${(item.animAmp ?? 4).toFixed(1)}px;
          --per:${(item.animPeriod ?? 5).toFixed(1)}s;
          --del:${(item.animDelay ?? 0).toFixed(1)}s;
          --ox:${(item.offX ?? 0).toFixed(0)}px;
          --oy:${(item.offY ?? 0).toFixed(0)}px;
        `}
      >
        <div class="n-l1-inner">
          <h2 class="n-l1-title">{item.content}</h2>
        </div>
      </a>
    ) : item.level === 2 ? (
      <span
        class="n n-l2"
        style={`
          left:${(item.x ?? 50).toFixed(1)}%;top:${(item.y ?? 50).toFixed(1)}%;
          --amp:${(item.animAmp ?? 3).toFixed(1)}px;
          --per:${(item.animPeriod ?? 5).toFixed(1)}s;
          --del:${(item.animDelay ?? 0).toFixed(1)}s;
          --ox:${(item.offX ?? 0).toFixed(0)}px;
          --oy:${(item.offY ?? 0).toFixed(0)}px;
        `}
      >{item.content}</span>
    ) : (
      <span
        class="n n-l3"
        style={`
          left:${(item.x ?? 50).toFixed(1)}%;top:${(item.y ?? 50).toFixed(1)}%;
          --amp:${(item.animAmp ?? 2).toFixed(1)}px;
          --per:${(item.animPeriod ?? 4).toFixed(1)}s;
          --del:${(item.animDelay ?? 0).toFixed(1)}s;
          --ox:${(item.offX ?? 0).toFixed(0)}px;
          --oy:${(item.offY ?? 0).toFixed(0)}px;
        `}
      >{item.content}</span>
    )
  ))}

  <a href="#signals" class="nebula-scroll"><span>↓</span></a>
</section>


