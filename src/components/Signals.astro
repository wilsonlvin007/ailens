---
import type { NewsItem } from '../data/types';
import { CATEGORIES, type Category } from '../data/categories';
import { importanceLabel } from '../lib/utils';

interface Props {
  items: NewsItem[];
  compact?: boolean;
}

const { items, compact = false } = Astro.props;

function getCatStyle(category: string): string {
  const cat = CATEGORIES[category as Category];
  if (!cat) return '';
  return `color: ${cat.color}; border-color: ${cat.color};`;
}
---

<section class="signals">
  <h2 class="signals-title">信号</h2>
  <div class="signals-grid">
    {items.map((item) => (
      <article class={`signal-card importance-${item.importance}`}>
        <div class="signal-header">
          <span class="signal-category" style={getCatStyle(item.category)}>
            {CATEGORIES[item.category as Category]?.icon || '📌'}
            {CATEGORIES[item.category as Category]?.label || item.category}
          </span>
          <span class="signal-importance">{importanceLabel(item.importance)}</span>
        </div>
        <a href={item.source} target="_blank" rel="noopener noreferrer" class="signal-title">
          {item.title}
        </a>
        {!compact && (
          <p class="signal-summary">{item.summary}</p>
        )}
        {!compact && item.analysis && (
          <details class="signal-analysis">
            <summary>深度解读</summary>
            <div class="analysis-content">{item.analysis}</div>
          </details>
        )}
        <div class="signal-meta">
          <span class="signal-source">{item.source_name}</span>
          <div class="signal-tags">
            {item.tags?.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .signals {
    padding: 1.5rem 0;
  }
  .signals-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text-primary);
  }
  .signals-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .signal-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border-light);
  }
  .signal-card:last-child {
    border-bottom: none;
  }
  .signal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .signal-category {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    border: 1px solid;
    letter-spacing: 0.02em;
  }
  .signal-importance {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }
  .signal-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 0.375rem;
    transition: color 0.2s;
  }
  .signal-title:hover {
    color: var(--accent);
  }
  .signal-summary {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .signal-analysis {
    margin-top: 0.75rem;
  }
  .signal-analysis summary {
    font-size: 0.8125rem;
    color: var(--accent);
    cursor: pointer;
    font-weight: 500;
    user-select: none;
  }
  .signal-analysis summary:hover {
    color: #1d4ed8;
  }
  .analysis-content {
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--accent-light);
    border-radius: var(--radius);
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--text-primary);
  }
  .signal-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.625rem;
  }
  .signal-source {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .signal-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  /* Importance visual hints */
  .importance-5 { border-left: 3px solid #dc2626; padding-left: 1rem; }
  .importance-4 { border-left: 3px solid #f59e0b; padding-left: 1rem; }

  @media (max-width: 640px) {
    .signal-meta { flex-direction: column; align-items: flex-start; gap: 0.375rem; }
  }
</style>
