---
import type { NewsItem } from '../data/types';
import { CATEGORIES, type Category } from '../data/categories';
import { importanceLabel } from '../lib/utils';

interface Props {
  items: NewsItem[];
  compact?: boolean;
  maxPerCategory?: number;
  dateLink?: string;
}

const { items, compact = false, maxPerCategory = 3, dateLink } = Astro.props;

// 按 category 分组，保持原始顺序
const groups: { key: Category; label: string; icon: string; color: string; items: NewsItem[] }[] = [];
const seen = new Set<string>();

for (const item of items) {
  const key = item.category as Category;
  if (!seen.has(key) && CATEGORIES[key]) {
    seen.add(key);
    groups.push({
      key,
      label: CATEGORIES[key].label,
      icon: CATEGORIES[key].icon,
      color: CATEGORIES[key].color,
      items: [],
    });
  }
  const group = groups.find(g => g.key === key);
  if (group) group.items.push(item);
}
---

<section class="signals">
  <h2 class="signals-title">焦点</h2>
  {groups.map((group) => (
    <div class="category-group">
      <div class="category-header" style={`border-color: ${group.color}`}>
        <span class="category-dot" style={`background: ${group.color}`}></span>
        <span class="category-label" style={`color: ${group.color}`}>{group.icon} {group.label}</span>
        <span class="category-count">{group.items.length}</span>
      </div>
      <div class="signals-list">
        {group.items.slice(0, maxPerCategory).map((item) => (
          <article class={`signal-card importance-${item.importance}`}>
            <div class="signal-header">
              <span class="signal-importance">{importanceLabel(item.importance)}</span>
            </div>
            <a href={item.source} target="_blank" rel="noopener noreferrer" class="signal-title">
              {item.title}
            </a>
            {!compact && (
              <p class="signal-summary">{item.summary}</p>
            )}
            {!compact && item.analysis && (
              <details class="signal-analysis">
                <summary>深度解读</summary>
                <div class="analysis-content">{item.analysis}</div>
              </details>
            )}
            <div class="signal-meta">
              <span class="signal-source">{item.source_name}</span>
              <div class="signal-tags">
                {item.tags?.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
      {group.items.length > maxPerCategory && dateLink && (
        <a href={dateLink} class="view-all">
          查看全部 {group.items.length} 条 →
        </a>
      )}
    </div>
  ))}
</section>

<style is:global>  .signals {
    padding: 1.5rem 0;
  }
  .signals-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }
  .category-group {
    margin-bottom: 1.75rem;
  }
  .category-group:last-child {
    margin-bottom: 0;
  }
  .category-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.625rem;
    border-bottom: 2px solid;
    margin-bottom: 0;
  }
  .category-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .category-label {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .category-count {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    margin-left: auto;
    font-weight: 500;
  }
  .signals-list {
    display: flex;
    flex-direction: column;
  }
  .signal-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border-light);
  }
  .signal-card:last-child {
    border-bottom: none;
  }
  .signal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .signal-importance {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }
  .signal-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.6;
    margin-bottom: 0.375rem;
    transition: color 0.2s;
  }
  .signal-title:hover {
    color: var(--accent);
  }
  .signal-summary {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .signal-analysis {
    margin-top: 0.75rem;
  }
  .signal-analysis summary {
    font-size: 0.8125rem;
    color: var(--accent);
    cursor: pointer;
    font-weight: 500;
    user-select: none;
  }
  .signal-analysis summary:hover {
    color: #1d4ed8;
  }
  .analysis-content {
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--accent-light);
    border-radius: var(--radius);
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--text-primary);
  }
  .signal-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.625rem;
  }
  .signal-source {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .signal-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }
  .view-all {
    display: block;
    text-align: center;
    padding: 0.625rem 0;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px dashed var(--border);
    border-radius: 6px;
    transition: background 0.2s, border-color 0.2s;
  }
  .view-all:hover {
    background: var(--accent-light);
    border-color: var(--accent);
    color: var(--accent-hover);
  }

  /* Importance visual hints */
  .importance-5 { border-left: 3px solid #dc2626; padding-left: 1rem; }
  .importance-4 { border-left: 3px solid #f59e0b; padding-left: 1rem; }

  @media (max-width: 640px) {
    .signal-meta { flex-direction: column; align-items: flex-start; gap: 0.375rem; }
  }
</style>
